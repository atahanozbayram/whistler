{
	"compilerOptions": {
		"baseUrl": "./",
		"paths": {
			"@root/*": ["./*"],
			"@middlewares/*": ["./src/middlewares/*"],
			"@routes/*": ["./src/routes/*"],
			"@tests/*": ["./src/middlewares/*"],
			"@utils/*": ["./src/utils/*"]
		}
	},
	"exclude": ["node_modules"],
	"typeAcquisition": {
		"include": ["jest"]
	}
}
